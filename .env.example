# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    AKILLI TOPLANTI ANALİZİ - ENV CONFIG                     ║
# ║         Tüm ortam değişkenleri bu tek dosyada toplanmıştır.                 ║
# ║         Bu dosyayı .env olarak kopyalayıp değerleri doldurun.               ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Sunucu / Ağ Ayarları ────────────────────────────────────────────────────
# Local geliştirme için: PUBLIC_IP=127.0.0.1, APP_DOMAIN=localhost
# Oracle sunucu için: PUBLIC_IP=<sunucu_ip>, APP_DOMAIN=<ip>.sslip.io
PUBLIC_IP=127.0.0.1
APP_DOMAIN=localhost
RTC_DOMAIN=localhost
TURN_DOMAIN=localhost

# ─── LiveKit Ayarları ────────────────────────────────────────────────────────
LIVEKIT_API_URL=http://livekit:7880
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace_with_long_secret

LIVEKIT_ROOM_EMPTY_TIMEOUT=300
LIVEKIT_ROOM_DEPARTURE_TIMEOUT=20
LIVEKIT_ROOM_MAX_PARTICIPANTS=4

LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTC_UDP_START=50000
LIVEKIT_RTC_UDP_END=50100

# ─── TURN Sunucusu ──────────────────────────────────────────────────────────
TURN_SECRET=replace_with_turn_shared_secret
TURN_RELAY_START=51000
TURN_RELAY_END=51100

# ─── Gateway Portları ────────────────────────────────────────────────────────
# Local: 8080/8443, Production: 80/443
GATEWAY_HTTP_PORT=8080
GATEWAY_HTTPS_PORT=8443

# ─── AI / Groq Ayarları ─────────────────────────────────────────────────────
GROQ_API_KEY=replace_with_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
AI_TRANSCRIBE_MODEL=whisper-large-v3

# ─── Celery / Redis ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
WORKER_CONCURRENCY=4

# ─── Kayıt ve Dataset Dizinleri ─────────────────────────────────────────────
RECORDING_OUTPUT_DIR=./recordings
DATASET_OUTPUT_DIR=./datasets

# ─── SSL / Genel ────────────────────────────────────────────────────────────
# Production'da true yapın
SSL_VERIFY=false
LOG_LEVEL=info

# ─── ACME (Production SSL) ──────────────────────────────────────────────────
# ACME_EMAIL=you@example.com
