port: 7880

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 50100
  use_external_ip: true
  allow_tcp_fallback: true

  # External TURN (Coturn) so HTTPS can stay on Caddy while TURN runs on 3478.
  turn_servers:
    - host: turn.example.com
      port: 3478
      protocol: udp
      secret: replace_with_turn_shared_secret
      ttl: 86400
    - host: turn.example.com
      port: 3478
      protocol: tcp
      secret: replace_with_turn_shared_secret
      ttl: 86400

room:
  empty_timeout: 300
  departure_timeout: 20

keys:
  devkey: replace_with_long_secret

webhook:
  api_key: devkey
  urls:
    - http://backend:8000/api/livekit/webhook
