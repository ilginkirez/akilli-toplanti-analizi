FROM node:20-slim AS frontend-build

WORKDIR /app/fullfrontend

COPY fullfrontend/package*.json ./
RUN npm ci

COPY fullfrontend/ ./
ARG VITE_API_URL=""
ARG VITE_LIVEKIT_URL=""
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_LIVEKIT_URL=$VITE_LIVEKIT_URL
RUN npm run build

FROM caddy:2.8-alpine

COPY Caddyfile.oracle /etc/caddy/Caddyfile
COPY --from=frontend-build /app/fullfrontend/dist /srv

