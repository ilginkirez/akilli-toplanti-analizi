# Local dev defaults
OPENVIDU_SECRET=MY_SECRET
OPENVIDU_URL=http://openvidu:4443
DOMAIN_OR_PUBLIC_IP=localhost
HTTPS_PORT=4443
FORCE_PLAIN_HTTP=true
OPENVIDU_WEBHOOK_ENDPOINT=http://backend:8000/api/openvidu/webhook
VITE_API_URL=

# Oracle Cloud / public deployment example:
# DOMAIN_OR_PUBLIC_IP=<your-public-domain-or-ip>
# HTTPS_PORT=443
# FORCE_PLAIN_HTTP=false
