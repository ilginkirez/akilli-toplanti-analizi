# Local LiveKit development defaults
LIVEKIT_API_URL=http://livekit:7880
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace_with_long_secret

LIVEKIT_ROOM_EMPTY_TIMEOUT=300
LIVEKIT_ROOM_DEPARTURE_TIMEOUT=20
LIVEKIT_ROOM_MAX_PARTICIPANTS=4

LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTC_UDP_START=50000
LIVEKIT_RTC_UDP_END=50100

TURN_DOMAIN=localhost
TURN_SECRET=replace_with_turn_shared_secret
TURN_RELAY_START=51000
TURN_RELAY_END=51100

PUBLIC_IP=127.0.0.1
APP_DOMAIN=localhost
RTC_DOMAIN=localhost
VITE_API_URL=
